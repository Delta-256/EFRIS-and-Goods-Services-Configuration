# EFRISConnect — environment variables
# Copy this file to .env and fill in your values.
# In production (Docker/Azure), set these as environment variables or GitHub Secrets.

# Port the Express server listens on (default: 3000)
PORT=3000

# EFRIS private key — either:
#   a) The full PEM content (paste the key directly, newlines as \n)
#   b) A file path to the PEM file (e.g. /app/keys/efris_private.pem)
# In Docker, this is passed as a build argument from the EFRIS_PRIVATE_KEY GitHub Secret.
EFRIS_PRIVATE_KEY=

# Internal API key — protects all /api/* routes from outside callers.
# If not set, a random key is generated at startup (valid for that session only).
# Set a stable value here if you need the key to survive container restarts
# (e.g. for external integrations or testing).
INTERNAL_API_KEY=
